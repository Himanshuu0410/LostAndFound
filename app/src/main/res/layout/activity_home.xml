<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <!-- Top Navbar -->
    <LinearLayout
        android:id="@+id/navbar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/surface"
        android:elevation="4dp">

        <TextView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="🔍"
            android:textSize="18sp"
            android:gravity="center"
            android:background="@drawable/btn_primary_accent"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Lost &amp; Found"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginStart="10dp"/>

        <ImageButton
            android:id="@+id/btnSignOut"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@drawable/bg_surface"
            android:tint="@color/text_muted"
            android:scaleType="center"/>
    </LinearLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="60dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Greeting -->
            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hello, User 👋"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="4dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Help reunite lost items with their owners"
                android:textSize="13sp"
                android:textColor="@color/text_muted"
                android:layout_marginBottom="20dp"/>

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <!-- Total -->
                <LinearLayout
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@drawable/bg_stat_card" android:padding="14dp"
                    android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📋" android:textSize="20sp" android:layout_marginBottom="6dp"/>
                    <TextView android:id="@+id/tvTotal" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="24sp" android:textStyle="bold" android:textColor="@color/accent"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Total" android:textSize="11sp" android:textColor="@color/text_muted"/>
                </LinearLayout>

                <!-- Lost -->
                <LinearLayout
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@drawable/bg_stat_card" android:padding="14dp"
                    android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔍" android:textSize="20sp" android:layout_marginBottom="6dp"/>
                    <TextView android:id="@+id/tvLost" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="24sp" android:textStyle="bold" android:textColor="@color/lost"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Lost" android:textSize="11sp" android:textColor="@color/text_muted"/>
                </LinearLayout>

                <!-- Found -->
                <LinearLayout
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@drawable/bg_stat_card" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✅" android:textSize="20sp" android:layout_marginBottom="6dp"/>
                    <TextView android:id="@+id/tvFound" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="24sp" android:textStyle="bold" android:textColor="@color/found"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Found" android:textSize="11sp" android:textColor="@color/text_muted"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Search -->
            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="🔎  Search items or locations…"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="14dp"/>

            <!-- Filter buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnAll"
                    android:layout_width="0dp" android:layout_height="38dp"
                    android:layout_weight="1" android:text="All Items"
                    android:textSize="12sp" android:textColor="@color/accent"
                    android:background="@drawable/btn_filter_active_all"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btnFilterLost"
                    android:layout_width="0dp" android:layout_height="38dp"
                    android:layout_weight="1" android:text="🔍 Lost"
                    android:textSize="12sp" android:textColor="@color/text_muted"
                    android:background="@drawable/btn_filter_inactive"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btnFilterFound"
                    android:layout_width="0dp" android:layout_height="38dp"
                    android:layout_weight="1" android:text="✅ Found"
                    android:textSize="12sp" android:textColor="@color/text_muted"
                    android:background="@drawable/btn_filter_inactive"/>
            </LinearLayout>

            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="40dp"
                android:visibility="gone">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🗂" android:textSize="48sp" android:layout_marginBottom="12dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="No items found" android:textSize="16sp" android:textColor="@color/text_muted"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Tap + to report a lost or found item"
                    android:textSize="13sp" android:textColor="@color/text_muted" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:text="+ Report"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:backgroundTint="@color/accent"
        app:iconTint="@color/white"
        app:elevation="6dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
