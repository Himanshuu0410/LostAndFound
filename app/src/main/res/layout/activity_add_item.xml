<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvBack"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="←" android:textSize="20sp" android:textColor="@color/text_muted"
                android:padding="8dp" android:layout_marginEnd="10dp"/>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Report Item" android:textSize="20sp"
                android:textStyle="bold" android:textColor="@color/text_primary"/>
        </LinearLayout>

        <!-- Item Name -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="ITEM NAME *" android:textSize="11sp" android:textColor="@color/text_muted"
            android:letterSpacing="0.06" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/etItemName"
            android:layout_width="match_parent" android:layout_height="50dp"
            android:hint="e.g. Black Leather Wallet"
            android:textColor="@color/text_primary" android:textColorHint="@color/text_muted"
            android:background="@drawable/bg_input" android:paddingHorizontal="14dp"
            android:layout_marginBottom="14dp"/>

        <!-- Category -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="CATEGORY" android:textSize="11sp" android:textColor="@color/text_muted"
            android:letterSpacing="0.06" android:layout_marginBottom="6dp"/>
        <Spinner android:id="@+id/spinnerCategory"
            android:layout_width="match_parent" android:layout_height="50dp"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="14dp"
            android:layout_marginBottom="14dp"/>

        <!-- Your Name -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="YOUR NAME *" android:textSize="11sp" android:textColor="@color/text_muted"
            android:letterSpacing="0.06" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/etPersonName"
            android:layout_width="match_parent" android:layout_height="50dp"
            android:hint="Full name"
            android:textColor="@color/text_primary" android:textColorHint="@color/text_muted"
            android:background="@drawable/bg_input" android:paddingHorizontal="14dp"
            android:layout_marginBottom="14dp"/>

        <!-- Phone -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="CONTACT NUMBER *" android:textSize="11sp" android:textColor="@color/text_muted"
            android:letterSpacing="0.06" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/etPhone"
            android:layout_width="match_parent" android:layout_height="50dp"
            android:hint="+91 98765 43210" android:inputType="phone"
            android:textColor="@color/text_primary" android:textColorHint="@color/text_muted"
            android:background="@drawable/bg_input" android:paddingHorizontal="14dp"
            android:layout_marginBottom="14dp"/>

        <!-- Location -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="LOCATION *" android:textSize="11sp" android:textColor="@color/text_muted"
            android:letterSpacing="0.06" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/etAddress"
            android:layout_width="match_parent" android:layout_height="50dp"
            android:hint="Where was it lost/found?"
            android:textColor="@color/text_primary" android:textColorHint="@color/text_muted"
            android:background="@drawable/bg_input" android:paddingHorizontal="14dp"
            android:layout_marginBottom="14dp"/>

        <!-- Description -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="DESCRIPTION" android:textSize="11sp" android:textColor="@color/text_muted"
            android:letterSpacing="0.06" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/etDescription"
            android:layout_width="match_parent" android:layout_height="100dp"
            android:hint="Describe the item in detail…"
            android:gravity="top" android:inputType="textMultiLine"
            android:textColor="@color/text_primary" android:textColorHint="@color/text_muted"
            android:background="@drawable/bg_input" android:paddingHorizontal="14dp"
            android:paddingTop="12dp"
            android:layout_marginBottom="14dp"/>

        <!-- Image -->
        <ImageView
            android:id="@+id/imgPreview"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_surface"
            android:visibility="gone"
            android:layout_marginBottom="10dp"/>

        <Button android:id="@+id/btnSelectImage"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="📷  Add Photo (Optional)"
            android:textColor="@color/text_muted"
            android:background="@drawable/btn_filter_inactive"
            android:layout_marginBottom="10dp"/>

        <!-- Error -->
        <TextView android:id="@+id/tvError"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="13sp" android:textColor="@color/lost"
            android:background="@drawable/badge_lost" android:padding="10dp"
            android:layout_marginBottom="14dp" android:visibility="gone"/>

        <!-- Save -->
        <Button android:id="@+id/btnSave"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="Submit Report"
            android:textSize="15sp" android:textStyle="bold" android:textColor="@color/white"
            android:background="@drawable/btn_primary_accent"
            android:layout_marginBottom="20dp"/>

    </LinearLayout>
</ScrollView>
