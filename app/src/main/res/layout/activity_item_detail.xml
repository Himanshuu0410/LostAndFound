<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Back -->
        <TextView
            android:id="@+id/tvBack"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="← Back"
            android:textSize="14sp" android:textColor="@color/text_muted"
            android:padding="6dp" android:layout_marginBottom="16dp"/>

        <!-- Image -->
        <ImageView
            android:id="@+id/imgItem"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_card"
            android:visibility="gone"
            android:layout_marginBottom="16dp"/>

        <!-- Badge + Status -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvBadge"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="LOST" android:textSize="11sp" android:textStyle="bold"
                android:background="@drawable/badge_lost" android:textColor="@color/lost"
                android:paddingHorizontal="12dp" android:paddingVertical="5dp"/>

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="✓ Resolved" android:textSize="12sp" android:textColor="@color/found"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Item name -->
        <TextView
            android:id="@+id/tvItemName"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="22sp" android:textStyle="bold" android:textColor="@color/text_primary"
            android:layout_marginBottom="4dp"/>

        <!-- Category -->
        <TextView
            android:id="@+id/tvCategory"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="12sp" android:textColor="@color/text_muted"
            android:background="@drawable/bg_surface"
            android:paddingHorizontal="10dp" android:paddingVertical="4dp"
            android:layout_marginBottom="20dp"/>

        <!-- Detail rows -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_card"
            android:padding="16dp" android:layout_marginBottom="14dp">

            <!-- Reported by -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="REPORTED BY" android:textSize="10sp" android:textColor="@color/text_muted"
                android:letterSpacing="0.06" android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/tvPersonName"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="15sp" android:textColor="@color/text_primary"
                android:layout_marginBottom="14dp"/>

            <!-- Location -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📍 LOCATION" android:textSize="10sp" android:textColor="@color/text_muted"
                android:letterSpacing="0.06" android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/tvAddress"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="15sp" android:textColor="@color/text_primary"
                android:layout_marginBottom="14dp"/>

            <!-- Phone -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📞 CONTACT" android:textSize="10sp" android:textColor="@color/text_muted"
                android:letterSpacing="0.06" android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/tvPhone"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="15sp" android:textColor="@color/teal"
                android:layout_marginBottom="14dp"/>

            <!-- Date -->
            <TextView android:id="@+id/tvDate"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="@color/text_muted"/>
        </LinearLayout>

        <!-- Description -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="DESCRIPTION" android:textSize="10sp" android:textColor="@color/text_muted"
            android:letterSpacing="0.06" android:layout_marginBottom="6dp"/>
        <TextView android:id="@+id/tvDescription"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="14sp" android:textColor="@color/text_primary"
            android:background="@drawable/bg_card" android:padding="14dp"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="20dp"/>

        <!-- Action buttons -->
        <Button
            android:id="@+id/btnContact"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="📞  Call Reporter"
            android:textSize="15sp" android:textStyle="bold" android:textColor="@color/white"
            android:background="@drawable/btn_primary_accent"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btnResolve"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="✓  Mark as Resolved"
            android:textSize="14sp" android:textColor="@color/found"
            android:background="@drawable/btn_outline_teal"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btnDelete"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="🗑  Delete Report"
            android:textSize="14sp" android:textColor="@color/lost"
            android:background="@drawable/btn_outline_danger"
            android:layout_marginBottom="20dp"/>

    </LinearLayout>
</ScrollView>
